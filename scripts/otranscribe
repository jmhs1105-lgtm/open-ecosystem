#!/bin/bash
# otranscribe - Transcribe audio usando Groq API (Whisper)
# Uso: otranscribe <audio-file>
# Ej:  otranscribe recording.m4a

set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Uso: otranscribe <audio-file>"
  echo "Ej:  otranscribe ~/Downloads/audio.m4a"
  exit 1
fi

AUDIO_FILE="$1"

if [ ! -f "$AUDIO_FILE" ]; then
  echo "Error: archivo no encontrado: $AUDIO_FILE"
  exit 1
fi

source ~/harnesses/.env

if [ -z "${GROQ_API_KEY:-}" ]; then
  echo "Error: GROQ_API_KEY no está definida en ~/harnesses/.env"
  exit 1
fi

# Verificar ffmpeg para convertir si es necesario
EXT="${AUDIO_FILE##*.}"
EXT_LOWER=$(echo "$EXT" | tr '[:upper:]' '[:lower:]')

# Si no es .mp3, .wav, .flac, .ogg, .m4a -> convertir a mp3
if [[ ! "$EXT_LOWER" =~ ^(mp3|wav|flac|ogg|m4a)$ ]]; then
  echo "Formato $EXT_LOWER no soportado directamente. Convirtiendo a mp3..."
  CONVERTED="/tmp/otranscribe_$$.mp3"
  ffmpeg -y -i "$AUDIO_FILE" -acodec libmp3lame -b:a 128k "$CONVERTED" 2>/dev/null
  AUDIO_FILE="$CONVERTED"
fi

echo "Transcribiendo $(basename "$AUDIO_FILE") con Groq Whisper..."

RESPONSE=$(curl -s -w "\n%{http_code}" \
  -H "Authorization: Bearer $GROQ_API_KEY" \
  -F "file=@$AUDIO_FILE" \
  -F "model=whisper-large-v3-turbo" \
  -F "response_format=json" \
  "https://api.groq.com/openai/v1/audio/transcriptions")

HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | sed '$d')

if [ "$HTTP_CODE" != "200" ]; then
  echo "Error ($HTTP_CODE): $BODY"
  exit 1
fi

TEXT=$(echo "$BODY" | python3 -c "import sys,json; print(json.load(sys.stdin).get('text',''))")

echo ""
echo "--- TRANSCRIPCIÓN ---"
echo "$TEXT"
echo "--- FIN ---"

# Limpiar archivo convertido temporal
if [ -n "${CONVERTED:-}" ] && [ -f "$CONVERTED" ]; then
  rm -f "$CONVERTED"
fi
