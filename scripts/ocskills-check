#!/usr/bin/env zsh
# ocskills-check — Validate skills structure across all agents
# Checks that each agent has skills.md, skills/ directory, and skill files

HARNESSES="$HOME/harnesses"
AGENTS_DIR="$HARNESSES/agents"
SKILLS_DIR="$HARNESSES/skills"
PASS=0
FAIL=0
WARN=0

ok()   { PASS=$((PASS+1)); echo "  ✅ $1"; }
fail() { FAIL=$((FAIL+1)); echo "  ❌ $1"; }
warn() { WARN=$((WARN+1)); echo "  ⚠️  $1"; }

echo "=== OpenCode Skills Validation ==="
echo ""

AGENTS=(
  orchestrator-ai-master
  android-architect
  react-native-expo
  backend-api
  insforge
  telegram-bot
  whatsapp-bot
  mcp-operations
  cloud-runtime
  ai-provider
  security-recovery
  software-architect
  research-agent
  team-skills-architect
)

echo "--- Agent skills.md ---"
for agent in "${AGENTS[@]}"; do
  FILE="$AGENTS_DIR/$agent/skills.md"
  if [ -f "$FILE" ]; then
    if [ -s "$FILE" ]; then
      ok "$agent/skills.md ($(wc -l < "$FILE" | tr -d ' ') lines)"
    else
      fail "$agent/skills.md is empty"
    fi
  else
    fail "$agent/skills.md missing"
  fi
done

echo ""
echo "--- Agent skills/ directories ---"
for agent in "${AGENTS[@]}"; do
  DIR="$AGENTS_DIR/$agent/skills"
  if [ -d "$DIR" ]; then
    COUNT=$(find "$DIR" -name "*.md" -type f | wc -l | tr -d ' ')
    if [ "$COUNT" -gt 0 ]; then
      ok "$agent/skills/ ($COUNT skill files)"
    else
      warn "$agent/skills/ exists but empty (no .md files)"
    fi
  else
    fail "$agent/skills/ directory missing"
  fi
done

echo ""
echo "--- Global Skills Index ---"
if [ -f "$SKILLS_DIR/SKILL_INDEX.md" ]; then
  ok "SKILL_INDEX.md present ($(wc -l < "$SKILLS_DIR/SKILL_INDEX.md" | tr -d ' ') lines)"
else
  fail "SKILL_INDEX.md missing"
fi

if [ -f "$SKILLS_DIR/SKILL_ROADMAP.md" ]; then
  ok "SKILL_ROADMAP.md present ($(wc -l < "$SKILLS_DIR/SKILL_ROADMAP.md" | tr -d ' ') lines)"
else
  fail "SKILL_ROADMAP.md missing"
fi

if [ -f "$HARNESSES/opencode/SKILLS_AUDIT.md" ]; then
  ok "SKILLS_AUDIT.md present"
else
  warn "SKILLS_AUDIT.md missing"
fi

if [ -f "$HARNESSES/opencode/SKILLS.md" ]; then
  ok "SKILLS.md (taxonomy) present"
else
  fail "SKILLS.md (taxonomy) missing"
fi

echo ""
echo "--- Skills Directories in ~/harnesses/skills/ ---"
for d in "$SKILLS_DIR"/*/; do
  name=$(basename "$d")
  if [ "$name" = "skills" ]; then continue; fi
  if [ -d "$d" ]; then
    ok "skills/$name/"
  fi
done

echo ""
echo "--- Security Check ---"
SECRET_FOUND=0
for agent in "${AGENTS[@]}"; do
  SKILL_DIR="$AGENTS_DIR/$agent/skills"
  if [ -d "$SKILL_DIR" ]; then
    for f in "$SKILL_DIR"/*.md(N); do
      if [ -f "$f" ]; then
        if grep -qiE '(api.?key\s*[:=]|token\s*[:=]\s*["'"'"'"][A-Za-z0-9]|secret\s*[:=]\s*["'"'"'"][A-Za-z0-9]|sk-[A-Za-z0-9]{20,}|ghp_[A-Za-z0-9]{36})' "$f" 2>/dev/null; then
          warn "Possible secret in $(basename "$(dirname "$(dirname "$f")")")/$(basename "$f")"
          SECRET_FOUND=$((SECRET_FOUND+1))
        fi
      fi
    done
  fi
done
if [ "$SECRET_FOUND" -eq 0 ]; then
  ok "No secrets in skill files"
fi

echo ""
echo "--- opencode.json ---"
if [ -f "$HOME/.config/opencode/opencode.json" ]; then
  if python3 -m json.tool "$HOME/.config/opencode/opencode.json" > /dev/null 2>&1; then
    ok "opencode.json valid"
  else
    fail "opencode.json invalid"
  fi
else
  warn "opencode.json not found"
fi

echo ""
echo "--- Summary ---"
TOTAL=$((PASS+FAIL+WARN))
TOTAL_SKILLS=$(find "$AGENTS_DIR" -path "*/skills/*.md" -type f | wc -l | tr -d ' ')
echo "  ✅ Pass: $PASS"
echo "  ❌ Fail: $FAIL"
echo "  ⚠️  Warn: $WARN"
echo "  Total:  $TOTAL"
echo "  Skill files created: $TOTAL_SKILLS / 218 planned"

if [ "$FAIL" -gt 0 ]; then
  echo ""
  echo "⚠️  $FAIL issue(s) found."
  exit 1
else
  echo ""
  echo "✅ Skills structure validated."
  exit 0
fi
